sub is_ctime_sort           {   $_[0]->options->{'c'} }
sub is_largest_first        {   $_[0]->options->{'S'} }
sub is_last_access_sort     {   $_[0]->options->{'u'} }
sub is_plain_dirs           {   $_[0]->options->{'d'} }
sub is_recursive            {   $_[0]->options->{'R'} }
sub is_reverse              {   $_[0]->options->{'r'} }
sub is_rich_dirs            { ! $_[0]->options->{'d'} }
sub is_modified_time_sort   {   $_[0]->options->{'t'} }
sub is_turn_off_sort        {   $_[0]->options->{'f'} }
sub show_blocks             {   $_[0]->options->{'s'} }
sub show_hidden             {   $_[0]->options->{'a'} }
sub show_uid_gid            {   $_[0]->options->{'n'} }
sub hide_hidden             { ! $_[0]->options->{'a'} }
sub show_inodes             {   $_[0]->options->{'i'} }
sub is_one_entry_per_line   {   scalar grep { $_[0]->options->{$_} } qw(1 l s i) }
sub is_long_listing         {   $_[0]->options->{'l'} }
sub is_time_sort {
	scalar grep { $_[0]->$_() } qw(is_ctime_sort is_last_access_sort is_modified_time_sort);
	}
sub force_multicolumn       {   $_[0]->options->{'C'} }
sub sort_across             {   $_[0]->options->{'x'} }

sub is_multicolumn          { scalar grep { $_[0]->$_() } qw(force_multicolumn is_long_listing sort_across) }

sub option_error {
	my($self, @args) = @_;

	foreach my $arg ( @args ) {
		if( $args[0] =~ /Option w requires an argument/ ) {
			$self->{'options'}->{'w'} =  $self->terminal_width;
			next;
			}

		$self->error( join ': ', $self->program_name, $arg );
		$self->{'option_errors'}++;
		}
	}

sub options_spec {
	return [qw(1 A C F L R S T W a c d f g i k l m n o p q r s t u version w=i x)];
	}

sub preprocess_options {
	my($self) = @_;
	return $self;
	}

sub postprocess_arguments {
	my($self) = @_;
	$self->{'arguments'} = [qw(.)] unless @{ $self->{'arguments'} }; # current directory if nothing else
	}

sub postprocess_options {
	my($self) = @_;

	$self->options->{'a'} = 1 if $self->options->{'f'};

	if( $self->is_multicolumn and ! $self->is_interactive_terminal ) {
		$self->options->{'1'} = 1;
		}

	if( ! defined $self->options->{'w'} ) {
		$self->options->{'w'} = $self->get_columns;
		}

	if( defined $self->options->{'w'} and $self->options->{'w'} == 0 ) {
		$self->options->{'w'} = $self->get_columns;
		}

	return $self;
	}


sub main {
	my($self) = @_;

	return $self->VERSION_MESSAGE if $self->options->{'version'};

	my @args = @{ $self->arguments };

	my $ArgCount = -1;  # file/directory argument count
	my %Attributes;     # File::stat directory entry attributes
	my @Dirs;           # directories in ARGV
	my @Files;          # non-directories in ARGV
	my $First = 1;      # first directory entry on command line

	foreach my $Arg (@args) {
		$ArgCount++;
		$Attributes{$Arg} = -l $Arg ? lstat($Arg) : stat($Arg);
		my $ref = ( -d $Arg and $self->is_rich_dirs ) ? \@Dirs : \@Files;
		push @$ref, $Arg;
		}

	if (@Files) {
		$First = 0;
		my %attrs;
		my @okfiles;
		foreach my $file (@Files) {
			my @ret = $self->DirEntries($file);
			next unless @ret; # stat() failed
			%attrs = (%attrs, %{ $ret[-1] });
			push @okfiles, $file;
			}
		my @sorted = $self->Order(\%Attributes, @okfiles);
		$self->List('.', 0, 0, @sorted, \%attrs);
		}

	foreach my $Arg ($self->Order(\%Attributes, @Dirs)) {
		if( ! $self->is_recursive ) {
			$self->output( "\n" ) unless $First;
			$First = 0;
			$self->output( "$Arg:\n" ) if $ArgCount > 0;
			}
		$self->List($Arg, 1, 0, $self->DirEntries($Arg));
		}
	}

sub start_time;

sub _supported_options {
	my $class = shift;
	my $opts_string = $class->_opts_string;
	$opts_string =~ s/\s+//g;
	my %Supported = map { $_, 1 } split //, $opts_string;
	return \%Supported;
	};

