    $self->output( $self->program_name . " version " . $self->VERSION . " (Perl Power Tools, Perl $^V)\n" );
    return $self->exit_code_success;
	}

sub DirEntries {
	my( $self, $file ) = @_;

	my %Attributes = ();
	my @Entries    = ();

	if( $self->is_plain_dirs || ! -d $file ) {
		if (-l $file or -e $file) {
			push @Entries, $file;
			$Attributes{$file} = -l $file ? lstat($file) : stat($file);
			push @Entries, \%Attributes;
			return @Entries;
			}
		$self->error( "can't access '$file': $!\n" );
		return;
		}

	my $dh;
	unless( opendir $dh, $file ) {
		$self->error( "failed to open directory '$file': $!\n" );
		return;
		}

	my $Name = "";
	while( $Name = readdir($dh) ) {
		next if ( $self->hide_hidden && $Name =~ m/^\./o);
		push @Entries, $Name;
		my $path = File::Spec->catfile( $file, $Name );
		$Attributes{$Name} = -l $path ? lstat($path) : stat($path);
		}
	closedir($dh);

	# ------ return list with %Attributes ref at end
	push @Entries, \%Attributes;
	return @Entries;
	}

BEGIN { # EntryFormat
	my @Month = (
		"Jan",
		"Feb",
		"Mar",
		"Apr",
		"May",
		"Jun",
		"Jul",
		"Aug",
		"Sep",
		"Oct",
		"Nov",
		"Dec"
	);

	sub EntryFormat {
		my( $self, $Attributes, $Dirname, $Entry ) = @_;

		my $max_file_size_length = do {
			my( $max ) =
				sort { $b <=> $a }
				map { $Attributes->{$_}->size }
				keys %$Attributes;

			length $max;
			};

		my $BlockSize =	$self->options->{'k'} ? 2 : 1;	# block size in 512-byte units

		if( $self->show_inodes ) {
			if( defined $Attributes->{$Entry} ) {
				$self->output( sprintf "%10d ", $Attributes->{$Entry}->ino );
				}
			else {
				$self->output( "_________ " );
				}
			}

		if( $self->show_blocks ) {
			if( defined $Attributes->{$Entry} ) {
				my $Blocks = $Attributes->{$Entry}->blocks;
				$Blocks = 0 if $Blocks eq '';
				$self->output( sprintf "%4d ",  $Blocks / $BlockSize + (($Blocks % $BlockSize) > 0) );
				}
			else {
				$self->output( "____ " );
				}
			}

		if( ! $self->is_long_listing ) {
			$self->output( "$Entry\n" );
			}
		else {
			if( ! defined $Attributes->{$Entry} ) {
				$self->output( <<'UNDEFSTAT' );
__________ ___ ________ ________ ________ ___ __  _____
UNDEFSTAT
				}
			else {
				my $mode = $self->format_mode($Attributes->{$Entry}->mode);
				$self->output( "$mode " );
				$self->output( sprintf "%3d ", $Attributes->{$Entry}->nlink );

				my $max_uid_length = 8;
				if( $self->show_uid_gid ) {
					$self->output( sprintf '%-*2$d ', $Attributes->{$Entry}->uid, $max_uid_length );
					}
				else {
					my $uid = $self->Getpwuid($Attributes->{$Entry}->uid);
					if( defined $uid ) {
						$self->output( sprintf '%-*2$s ', $uid, $max_uid_length );
						}
					else {
						$self->output( sprintf'%-*2$d ', $Attributes->{$Entry}->uid, $max_uid_length );
						}
					}

				my $max_gid_length = 8;
				if( $self->show_uid_gid ) {
					$self->output( sprintf '%-*2$d ', $Attributes->{$Entry}->gid, $max_gid_length );
					}
				else {
					my $gid = $self->Getgrgid($Attributes->{$Entry}->gid);
					my $max_gid_length = 8;
					if( defined $gid ) {
						$self->output( sprintf '%-*2$s ', $gid, $max_gid_length );
						}
					else {
						$self->output( sprintf '%-*2$d ', $Attributes->{$Entry}->gid, $max_gid_length );
						}
					}

				my $size_width = 9;
				if( $Attributes->{$Entry}->mode & 0140000 ) {
					$self->output( sprintf '%*2$d ', $Attributes->{$Entry}->size, $max_file_size_length );
					}
				else {
					$self->output( sprintf "%4x,%4x ",
						(($Attributes->{$Entry}->dev & 0xFFFF000) > 16),
						$Attributes->{$Entry}->dev & 0xFFFF
						);
					}

				my $time = $Attributes->{$Entry}->mtime;
				$time = $Attributes->{$Entry}->ctime if $self->is_ctime_sort;
				$time = $Attributes->{$Entry}->atime if $self->is_last_access_sort;

				my($sec, $min, $hour, $mday, $mon, $year, $wday, $yday, $isdst) = localtime($time);
				$self->output( $Month[$mon] );
				$self->output( sprintf " %2d ", $mday );

				if( start_time() - $time <= SIX_MONTHS_SECONDS ) {
					$self->output( sprintf "%02d:%02d", $hour, $min );
					}
				else {
					$self->output( sprintf " %04d", $year + 1900 );
					}
				}
			}

		my $path = File::Spec->catfile($Dirname, $Entry);
		if( -l $path ) {
			my $target = readlink( $path );
			$Entry .= " -> $target";
			}
		$self->output( " $Entry\n" );
		}
	}

sub List {
	my $Attributes = pop(@_);
	my( $self, $dir_name, $is_dir, $Expand, @files ) = @_;

	my $total_blocks    = 0;
	my $max_file_length = 0;

	foreach my $file (@files) {
		$total_blocks +=
			(!defined($Attributes->{$file}) || ($Attributes->{$file}->blocks eq '')) ? 0 : $Attributes->{$file}->blocks;
		my $l = length $file;
		$max_file_length = $l if $l > $max_file_length;
		}
	$max_file_length += 1;	# account for spaces

	if( $is_dir ) {
		$self->output( "$dir_name:\n" ) if $self->is_recursive;
		$self->output( "total $total_blocks\n" ) if( $self->show_blocks or $self->show_inodes );
		}

	my @SortedEntries = $self->Order($Attributes, @files);

	if( $self->is_one_entry_per_line ) {
		for my $entry (@SortedEntries) {
			$self->EntryFormat( $Attributes, $dir_name, $entry );
			}
		}
	else {
		my $Cols    = (int($self->options->{'w'} / $max_file_length)) || 1;
		my $Rows    = int(($#_+$Cols) / $Cols);
		my $template = sprintf "%%-%ds ", $max_file_length;

		my $elt;
		for ($elt = 0; $elt < $Rows * $Cols; $elt++) {
			my $target = ($elt % $Cols) * $Rows + int(($elt / $Cols));
			my $piece = sprintf $template, $target < ($#SortedEntries + 1) ? $SortedEntries[$target] : "";
			# don't blank pad to eol of line
			$piece =~ s/\s+$// if (($elt+1) % $Cols == 0);
			$self->output( $piece );
			$self->output( "\n" ) if (($elt+1) % $Cols == 0);
			}
		$self->output( "\n" ) if (($elt+1) % $Cols == 0);
		}

	# ------ print blank line if -R
	$self->output( "\n" ) if $self->is_recursive;

	# ------ list subdirectories of this directory
	if( $self->is_rich_dirs && ($Expand || $self->is_recursive )) {
		for my $entry ($self->Order($Attributes, @files)) {
			next if ($entry eq "." || $entry eq "..");
			if (defined($Attributes->{$entry}) && $Attributes->{$entry}->mode & 0040000) {
				my $path = File::Spec->canonpath(File::Spec->catdir($dir_name,$entry));
				my @dirs = $self->DirEntries($path);
				$self->List($path, 1, 0, @dirs);
				}
			}
		}
	}

sub Order {
	my( $self, $A, @Entries ) = @_;

	my $method = do {
		if(    $self->is_largest_first )        { 'size'  }
		elsif( $self->is_time_sort     ) {
			   if( $self->is_last_access_sort ) { 'atime' }
			elsif( $self->is_ctime_sort )       { 'ctime' }
			else                                { 'mtime' }
			}
		elsif( ! $self->is_turn_off_sort )      { undef }
		};

	my $sub =
		! $self->is_turn_off_sort
			?
		sub { $_[0] cmp $_[1] }
			:
		sub { $A->{$_[0]}->$method()  <=> $A->{$_[1]}->$method()  }
			;

	@Entries = sort {
		$sub->($a, $b)
		} @Entries;

	@Entries = reverse @Entries if $self->is_reverse;

	return @Entries;
	}

sub Getgrgid { getgrgid($_[1]) }
sub Getpwuid { getpwuid($_[1]) }

BEGIN {
	my $NO_GETGRGID = ! eval { my $dummy = ""; $dummy = (getpwuid(0))[0] };

	if( $NO_GETGRGID ) {
		no warnings qw(redefine);
		no strict qw(refs);
		*{'Getgrgid'} = sub { ($_[1], 0) };
		*{'Getpwuid'} = sub { ($_[1], 0) };
		}
	}

